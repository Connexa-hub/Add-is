# ─────────────────────────────────────────────────────────────
# REQUIRED — the app will refuse to start without these
# ─────────────────────────────────────────────────────────────

# MongoDB Configuration
MONGO_URI=

# Authentication
# Must be at least 32 random characters — generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Monnify Payment Gateway (virtual accounts, wallet funding, webhooks)
MONNIFY_API_KEY=
MONNIFY_SECRET_KEY=
MONNIFY_CONTRACT_CODE=

# ─────────────────────────────────────────────────────────────
# OPTIONAL — app boots without these, but the related feature
# (VTU purchases / email delivery) won't work until they're set
# ─────────────────────────────────────────────────────────────

# Monnify base URL — defaults to the sandbox if unset. Set explicitly to
# https://api.monnify.com in production.
MONNIFY_BASE_URL=https://sandbox.monnify.com

# VTPass API Configuration
VTPASS_API_KEY=
VTPASS_PUBLIC_KEY=
VTPASS_BASE_URL=
VTPASS_USERNAME=
VTPASS_SECRET_KEY=

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=your-email@gmail.com

# GitHub Repository URL
GITHUB_URL=https://github.com/connexa-tech/addis-digital-banking

# Environment
NODE_ENV=development
PORT=3001

# ─────────────────────────────────────────────────────────────
# Secret rotation policy
# ─────────────────────────────────────────────────────────────
# JWT_SECRET: rotating it invalidates every existing session/token
#   immediately (no grace period yet — see ROADMAP.md Phase 2, which adds
#   refresh-token rotation and a tokenVersion-based path to rotate without
#   forcing a hard logout of every user at once). Rotate on suspected
#   compromise; otherwise at minimum annually.
# MONNIFY_API_KEY / MONNIFY_SECRET_KEY: rotate via the Monnify dashboard,
#   update here, redeploy. Rotating SECRET_KEY also invalidates webhook
#   signature verification for any in-flight webhook signed with the old
#   key — coordinate the rotation with Monnify support to avoid dropping
#   legitimate webhook events during the cutover.
# VTPASS_SECRET_KEY: rotate via the VTPass dashboard, update, redeploy.
# EMAIL_PASSWORD: if using a Gmail app password, revoke and regenerate from
#   the Google Account security settings; update here, redeploy.
# None of these secrets should ever be committed — .env is gitignored
# (verified) and this repo's history was checked for hardcoded secrets in
# source (none found as of this audit — see SECURITY_REPORT.md).
